import cartopy.crs as ccrs
import cartopy.feature as cfeature
import numpy as np
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
proj = ccrs.PlateCarree()
sst_grid = bob["sst"]
clim = sst_grid.groupby("time.month").mean("time")
anom = sst_grid.groupby("time.month") - clim
year_sel  = 2023
month_sel = 1
time_str  = f"{year_sel}-{month_sel:02d}-01"
anom_sel = anom.sel(time=time_str)
vmax = float(np.nanmax(np.abs(anom_sel.values)))
vmin = -vmax
fig = plt.figure(figsize=(14, 6))
ax1 = fig.add_subplot(1, 2, 1)
mesh1 = ax1.pcolormesh(
    anom_sel["lon"],
    anom_sel["lat"],
    anom_sel,
    cmap="coolwarm",
    shading="auto",
    vmin=vmin,
    vmax=vmax
)
ax1.set_xlabel("Longitude (°E)")
ax1.set_ylabel("Latitude (°N)")
ax1.set_title(f"SST Anomalies (No Map)\nBay of Bengal – {year_sel}-01")
ax1.grid(True, linestyle="--", linewidth=0.5, alpha=0.7)
yticks = np.arange(5, 26, 5)
ax1.set_yticks(yticks)
ax1.set_yticklabels([f"{lat:.0f}°N" for lat in yticks])
for label in ax1.get_yticklabels():
    label.set_rotation(90)
    label.set_verticalalignment("center")
    label.set_horizontalalignment("right")
ax1.set_aspect("equal", adjustable="box")
fig.colorbar(mesh1, ax=ax1, label="SST Anomaly (°C)")
ax2 = fig.add_subplot(1, 2, 2, projection=proj)
mesh2 = ax2.pcolormesh(
    anom_sel["lon"],
    anom_sel["lat"],
    anom_sel,
    cmap="coolwarm",
    shading="auto",
    vmin=vmin,
    vmax=vmax,
    transform=proj,
    zorder=0
)
ax2.add_feature(
    cfeature.LAND,
    facecolor="lightgray",
    edgecolor="black",
    zorder=1
)
ax2.coastlines(resolution="110m", linewidth=0.8, zorder=2)
ax2.set_extent([80, 100, 5, 25], crs=proj)
gl = ax2.gridlines(
    draw_labels=True,
    linestyle="--",
    linewidth=0.5,
    alpha=0.7
)
gl.top_labels = False
gl.right_labels = False
gl.ylabel_style = {"rotation": 90, "va": "center", "ha": "right"}
ax2.set_title(f"SST Anomalies on PlateCarree Map\nBay of Bengal – {year_sel}-01")
fig.colorbar(mesh2, ax=ax2, label="SST Anomaly (°C)")
plt.suptitle(
    f"Bay of Bengal Sea Surface Temperature Anomalies – January {year_sel}",
    fontsize=14,
    y=1.02
)
plt.tight_layout()
plt.show()



