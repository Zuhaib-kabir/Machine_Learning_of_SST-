import xarray as xr
import fsspec
import io
# Remote NOAA PSL NetCDF file (accessed via HTTPS)
url = "https://downloads.psl.noaa.gov/Datasets/noaa.oisst.v2/sst.mnmean.nc"
# NOTE:
# - This does NOT require you to manually download a file in advance.
# - Colab reads the file from the remote server.
# - Here I read it into RAM (BytesIO). Nothing is permanently saved unless I export it myselves.
with fsspec.open(url, "rb") as f:
    buffer = io.BytesIO(f.read())
# Open the NetCDF dataset from the in-memory buffer
ds = xr.open_dataset(buffer, engine='scipy')
print(ds)



