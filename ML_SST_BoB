4) Area-mean SST time series for Bay of Bengal
# Compute area-mean SST over the Bay of Bengal for each month
sst_bob = bob["sst"].mean(dim=["lat", "lon"])
# Convert to a tidy pandas table: time + SST
df = sst_bob.to_dataframe(name="sst").reset_index()
# Time features (year/month + a running time index)
df["year"] = df["time"].dt.year
df["month"] = df["time"].dt.month
df["t_index"] = np.arange(len(df))
# Drop any missing values
df = df.dropna(subset=["sst"]).reset_index(drop=True)
df.head()





#Long-term trend
plt.figure()
plt.plot(df["time"], df["sst"])
plt.xlabel("Year")
plt.ylabel("SST (°C)")
plt.title("Bay of Bengal Monthly Mean SST (2000–2023)")
plt.grid(True)
plt.show()




#Mean seasonal cycle (climatology)
seasonal = df.groupby("month")["sst"].mean()
plt.figure()
plt.plot(seasonal.index, seasonal.values, marker="o")
plt.xlabel("Month")
plt.ylabel("SST (°C)")
plt.title("Seasonal Cycle of SST in Bay of Bengal")
plt.xticks(range(1, 13))
plt.grid(True)
plt.show()



#5) Prepare data for ML

# Encode month seasonality as cyclic features (avoids treating Dec and Jan as “far apart”)
df["month_sin"] = np.sin(2 * np.pi * df["month"] / 12)
df["month_cos"] = np.cos(2 * np.pi * df["month"] / 12)
# Features: long-term time index + seasonal cycle
feature_cols = ["t_index", "month_sin", "month_cos"]
X = df[feature_cols].values
# Target: use SST or SST anomaly depending on your choice
y = df["sst"].values    # or df["sst_anom"].values if using anomalies
# Train/test split WITHOUT shuffling to preserve time order (important for time series)
X_train, X_test, y_train, y_test, time_train, time_test = train_test_split(
    X, y, df["time"].values, test_size=0.2, shuffle=False
)





#6)Train Linear Regression & Random Forest
linreg = LinearRegression()
linreg.fit(X_train, y_train)
y_pred_lr = linreg.predict(X_test)
mse_lr = mean_squared_error(y_test, y_pred_lr)
rmse_lr = np.sqrt(mse_lr)
mae_lr = mean_absolute_error(y_test, y_pred_lr)
r2_lr = r2_score(y_test, y_pred_lr)
print("Linear Regression:")
print(f"  RMSE = {rmse_lr:.3f} °C")
print(f"  MAE  = {mae_lr:.3f} °C")
print(f"  R²   = {r2_lr:.3f}")



#Random Forest Regressor
rf = RandomForestRegressor(
    n_estimators=300,
    max_depth=6,
    random_state=42
)
rf.fit(X_train, y_train)
y_pred_rf = rf.predict(X_test)
mse_rf = mean_squared_error(y_test, y_pred_rf)
rmse_rf = np.sqrt(mse_rf)
mae_rf = mean_absolute_error(y_test, y_pred_rf)
r2_rf = r2_score(y_test, y_pred_rf)
print("Random Forest:")
print(f"  RMSE = {rmse_rf:.3f} °C")
print(f"  MAE  = {mae_rf:.3f} °C")
print(f"  R²   = {r2_rf:.3f}")



#7) Professional-looking comparison plots
plt.figure()
plt.plot(time_test, y_test, label="Observed", linewidth=2)
plt.plot(time_test, y_pred_lr, label="Linear Regression", linestyle="--")
plt.plot(time_test, y_pred_rf, label="Random Forest", linestyle=":")
plt.xlabel("Year")
plt.ylabel("SST (°C)")
plt.title("SST Prediction over Bay of Bengal – Test Period")
plt.legend()
