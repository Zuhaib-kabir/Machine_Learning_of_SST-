import xarray as xr
import numpy as np
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
from cartopy.mpl.ticker import LongitudeFormatter, LatitudeFormatter
from matplotlib.colors import BoundaryNorm
# 1. File path
gebco_file = "/content/drive/MyDrive/Data/GEBCO_2024_CF.nc"
# 2. Study region
lon_min, lon_max = 80, 100
lat_min, lat_max = 5, 25
# 3. Open GEBCO data
ds = xr.open_dataset(gebco_file)
print(ds)
# GEBCO usually uses variable name "elevation"
# elevation: positive = land, negative = ocean depth
elev = ds["elevation"]
# 4.Subset region
elev_sub = elev.sel(
    lon=slice(lon_min, lon_max),
    lat=slice(lat_min, lat_max)
)
# Optional: coarsen if plotting is slow
# Keep this ON for faster plotting in Colab
elev_sub = elev_sub.coarsen(lat=2, lon=2, boundary="trim").mean()
lon = elev_sub["lon"]
lat = elev_sub["lat"]
# 5. Separate ocean and land
ocean_depth = elev_sub.where(elev_sub < 0)
land = elev_sub.where(elev_sub >= 0)
# Convert depth to positive values for colorbar
depth_positive = -ocean_depth
# 6. Plot
fig = plt.figure(figsize=(9, 8), dpi=300)
ax = plt.axes(projection=ccrs.PlateCarree())
ax.set_extent(
    [lon_min, lon_max, lat_min, lat_max],
    crs=ccrs.PlateCarree()
)
# Bathymetry filled color
depth_levels = [0, 20, 50, 100, 200, 500, 1000, 2000, 3000, 4000, 5000]
cmap = plt.cm.Blues
norm = BoundaryNorm(depth_levels, cmap.N)
bath = ax.pcolormesh(
    lon,
    lat,
    depth_positive,
    cmap=cmap,
    norm=norm,
    shading="auto",
    transform=ccrs.PlateCarree()
)
# Land mask
ax.contourf(
    lon,
    lat,
    land,
    levels=[0, 9000],
    colors=["lightgray"],
    transform=ccrs.PlateCarree(),
    zorder=3
)
# Coastline and borders
ax.coastlines(resolution="10m", linewidth=1.0, color="black", zorder=5)
ax.add_feature(
    cfeature.BORDERS,
    linewidth=0.6,
    edgecolor="black",
    zorder=5
)
# Bathymetry contour lines
contour_levels = [-4000, -3000, -2000, -1000, -500, -200] # Changed to increasing order
cs = ax.contour(
    lon,
    lat,
    elev_sub,
    levels=contour_levels,
    colors="black",
    linewidths=0.5,
    alpha=0.6,
    transform=ccrs.PlateCarree(),
    zorder=4
)
ax.clabel(
    cs,
    inline=True,
    fontsize=7,
    fmt="%d m"
)
# Hatching for shallow shelf / selected sea region
# Example: ocean shallower than 200 m
shelf_mask = elev_sub.where((elev_sub < 0) & (elev_sub >= -200))
ax.contourf(
    lon,
    lat,
    shelf_mask,
    levels=[-200, 0],
    colors="none",
    hatches=["///"],
    transform=ccrs.PlateCarree(),
    zorder=6
)
# Add gridlines
gl = ax.gridlines(
    draw_labels=True,
    linewidth=0.4,
    color="gray",
    alpha=0.5,
    linestyle="--"
)
gl.top_labels = False
gl.right_labels = False
gl.xlabel_style = {"size": 10}
gl.ylabel_style = {"size": 10}
ax.xaxis.set_major_formatter(LongitudeFormatter())
ax.yaxis.set_major_formatter(LatitudeFormatter())
# Add labels
ax.text(
    90, 16,
    "Bay of Bengal",
    fontsize=12,
    color="darkgreen",
    fontweight="bold",
    transform=ccrs.PlateCarree()
)
ax.text(
    88.5, 24.5,
    "Bangladesh",
    fontsize=9,
    color="red",
    fontweight="bold",
    transform=ccrs.PlateCarree()
)
# Colorbar
cbar = plt.colorbar(
    bath,
    ax=ax,
    orientation="vertical",
    shrink=0.75,
    pad=0.03,
    ticks=depth_levels
)
cbar.set_label("Ocean depth (m)", fontsize=11)
plt.tight_layout()
# Save figure
out_fig = "/content/Bay_of_Bengal_Bathymetry_Map.png"
plt.savefig(out_fig, dpi=300, bbox_inches="tight")
plt.show()
print("Saved figure:", out_fig)




