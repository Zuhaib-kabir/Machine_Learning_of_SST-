#Scatter: predicted vs observed
def scatter_plot(y_true, y_pred, title):
    plt.figure()
    plt.scatter(y_true, y_pred, alpha=0.7)
    min_val = min(y_true.min(), y_pred.min())
    max_val = max(y_true.max(), y_pred.max())
    plt.plot([min_val, max_val], [min_val, max_val], "k--", linewidth=2)
    plt.xlabel("Observed SST (°C)")
    plt.ylabel("Predicted SST (°C)")
    plt.title(title)
    plt.grid(True)
    plt.tight_layout()
    plt.show()
scatter_plot(y_test, y_pred_lr, "Observed vs Predicted SST – Linear Regression")
scatter_plot(y_test, y_pred_rf, "Observed vs Predicted SST – Random Forest")



#Residuals over time (for Random Forest)
residuals_rf = y_test - y_pred_rf
plt.figure()
plt.axhline(0, color="k", linewidth=1)
plt.plot(time_test, residuals_rf, marker="o", linestyle="-")
plt.xlabel("Year")
plt.ylabel("Residual (Observed − Predicted) [°C]")
plt.title("Random Forest Residuals – Test Period")
plt.grid(True)
plt.tight_layout()
plt.show()



